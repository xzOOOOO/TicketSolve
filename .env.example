# LLM 配置 符合openai接口规范
LLM_API_KEY=your-api-key-here
LLM_MODEL=your-model-here
LLM_BASE_URL=your-base-url-here

# LLM 限流配置
LLM_MAX_CONCURRENT=5  # 最大并发数
LLM_RPM_LIMIT=60  # 每分钟请求数

# 数据库配置
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tickets
DB_ECHO=true

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true